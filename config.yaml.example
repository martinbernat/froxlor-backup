# ============================================================
# froxlor-backup - configuration file
# Copy in /etc/froxlor-backup/config.yaml and modify
# ============================================================

# --- Froxlor DB (unprivileged, read-only access is enough) ---
froxlor_db:
  host: localhost
  port: 3306
  socket: null            # alternative to host+port, e.g. /var/run/mysqld/mysqld.sock
  user: froxlor           # see /var/www/froxlor/lib/userdata.inc.php  ($sql['user'])
  password: "secret"      # see userdata.inc.php ($sql['password'])
  name: froxlor           # see userdata.inc.php ($sql['db'])

# --- Root access to MySQL server (for mysqldump)
# Froxlor saves these in /var/www/froxlor/lib/userdata.inc.php
# in fields $sql_root[0], $sql_root[1], ...
# Index must match the number dbserver in panel_databases
db_root_servers:
  0:                             # dbserver=0 (default)
    host: localhost
    port: 3306
    socket: null
    user: root
    password: "root_pwd"
  # 1:                           # next MySQL server (if any)
  #   host: db2.internal
  #   port: 3306
  #   user: root
  #   password: "password2"

# --- Froxlor paths (must match Froxlor admin panel settings)
# Admin → Settings → System → Pa
froxlor_paths:
  document_root_prefix: /var/customers/webs    # system.documentroot_prefix
  mail_home_dir: /var/customers/mail           # system.vmail_homedir
  logs_dir: /var/customers/logs                # system.logfiles_directory

# --- What to backup ---
backup:
  web: true           # files from documentroot of the domain
  mail: true          # mailboxes (per domain and according to mail_users.domainid)
  databases: true     # SQL dump all DBs of a customer
  logs: false         # access/error logy (not needed in most cases)

# --- Local backups folder (staging) ---
local_backup_dir: /var/backups/froxlor-backup

# --- Domainsy/Customers to Skip ---
exclude_domains: []          # ["test.example.com", "dev.example.com"]
exclude_customers: []        # ["web1", "web2"]
include_only_customers: []   # if NOT empty, backup ONLY these customers

# --- Remote storage ---
# Multiple can be defined - if all enabled:true, all will be used
remotes:
  - name: backup-ssh
    type: rsync_ssh
    enabled: true
    host: backup.example.com
    port: 22
    user: backupuser
    key_file: /root/.ssh/froxlor_backup_rsa
    path: /mnt/backups/froxlor
    # Optional rsync flags
    rsync_extra_args: ["--bwlimit=50000"]    # 50 MB/s throttle

  - name: s3-wasabi
    type: rclone
    enabled: false
    rclone_remote: wasabi                    # name from rclone config
    path: my-bucket/froxlor-backups
    rclone_config: /root/.config/rclone/rclone.conf   # optional
    rclone_extra_args: ["--transfers=4"]

  # - name: hetzner-sftp
  #   type: rclone
  #   enabled: false
  #   rclone_remote: hetzner-sftp
  #   path: froxlor-backups

# --- Retention (in local folder; rsync deletes also from remote) ---
retention:
  daily: 7       # last 7 days
  weekly: 4      # 1 backup/week, last 4 weeks
  monthly: 6     # 1 backup/month, last 6 months

# --- Notifications ---
notifications:
  enabled: false
  email_to: admin@example.com
  email_from: froxlor-backup@example.com
  smtp_host: localhost
  smtp_port: 25
  smtp_user: null
  smtp_password: null
  # smtp_tls:
  #   false     - plain, no encryption          (port 25,  local relay)
  #   starttls  - plain connect, then STARTTLS  (port 587, most providers)
  #   ssl       - direct TLS from first byte    (port 465, SMTPS)
  smtp_tls: false
  on_error: true     # send mail on error
  on_success: false  # send mail on success

# --- Logging ---
log_file: /var/log/froxlor-backup.log
log_level: INFO    # DEBUG / INFO / WARNING / ERROR
